# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Remove.bg API — https://www.remove.bg/api
REMOVE_BG_API_KEY=

# Google Sign-In — the WEB OAuth client ID from Google Cloud Console
# (APIs & Services → Credentials). Used as the ID-token audience that Supabase
# verifies. The Android OAuth client (with your SHA-1) is registered in the
# same Google project but is NOT referenced here.
GOOGLE_WEB_CLIENT_ID=

# Truecaller — OAuth SDK 3.0 Android Client ID from the Truecaller developer
# console (https://developer.truecaller.com). Generate it for the app's package
# name (com.footprint.zingo) + your build's SHA-1. Public PKCE client id;
# the token exchange is re-verified server-side in the truecaller-auth Edge
# Function. Set the same value as an Edge Function secret:
#   supabase secrets set TRUECALLER_CLIENT_ID=...
TRUECALLER_CLIENT_ID=

# EAS — run `eas init` inside the project to generate this
EAS_PROJECT_ID=

# Google Gemini — https://aistudio.google.com/app/apikey (free tier, for scripts/detect-photo-slots.js)
GEMINI_API_KEY=

# Supabase service role key — Settings → API → service_role (server-side scripts only, never in app)
SUPABASE_SERVICE_KEY=

# Razorpay — https://dashboard.razorpay.com/app/keys
# Only the PUBLIC key id goes in the app. The key SECRET and webhook secret
# are set on the server (Supabase Edge Functions), NEVER here:
#   supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=... \
#     RAZORPAY_WEBHOOK_SECRET=...
RAZORPAY_KEY_ID=
